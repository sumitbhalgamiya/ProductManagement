@{
    ViewData["Title"] = "Home Page";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        background-color: #f4f7fc;
        font-family: 'Segoe UI', sans-serif;
    }

    .page-wrapper {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .content-wrapper {
        flex: 1;
    }

    /* HERO SECTION */
    .hero-section {
        background: linear-gradient(135deg, #0d6efd, #4e73df);
        color: white;
        padding: 80px 30px;
        border-radius: 20px;
        text-align: center;
        margin-top: 30px;
        margin-bottom: 50px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

        .hero-section h1 {
            font-size: 55px;
            font-weight: bold;
        }

        .hero-section p {
            font-size: 20px;
            margin-top: 15px;
        }

    /* CAROUSEL */
    .carousel {
        border-radius: 20px;
        overflow: hidden;
    }

    .carousel-item img {
        height: 500px;
        object-fit: cover;
        filter: brightness(75%);
    }

    .carousel-caption {
        bottom: 100px;
    }

        .carousel-caption h3 {
            font-size: 40px;
            font-weight: bold;
        }

        .carousel-caption p {
            font-size: 20px;
        }

    /* FIX CAROUSEL ICONS */
    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        background-size: 60% 60%;
        background-color: rgba(0,0,0,0.7);
        border-radius: 50%;
        padding: 25px;
    }

    .carousel-control-prev,
    .carousel-control-next {
        width: 8%;
    }

    /* INDICATORS */
    .carousel-indicators button {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        margin: 0 5px;
    }

    /* SECTION TITLE */
    .section-title {
        text-align: center;
        margin-bottom: 40px;
        font-weight: bold;
        color: #0d6efd;
    }

    /* FEATURE CARDS */
    .feature-card {
        border: none;
        border-radius: 20px;
        transition: 0.3s;
        overflow: hidden;
    }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.12);
        }

    .feature-icon {
        font-size: 50px;
        margin-bottom: 20px;
    }

    .feature-card .card-body {
        padding: 35px 25px;
    }

    .btn-custom {
        border-radius: 30px;
        padding: 10px 25px;
        font-weight: 600;
    }

    /* ABOUT SECTION */
    .about-section {
        margin-top: 80px;
        margin-bottom: 80px;
    }

    .about-image {
        border-radius: 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    /* FOOTER */
    .footer {
        background-color: #0d6efd;
        color: white;
        text-align: center;
        padding: 20px 10px;
        margin-top: auto;
    }

        .footer p {
            margin: 0;
            font-size: 16px;
        }

    /* RESPONSIVE */
    @@media(max-width:768px) {

        .hero-section h1 {
            font-size: 38px;
        }

        .carousel-item img {
            height: 280px;
        }

        .carousel-caption {
            bottom: 20px;
        }

            .carousel-caption h3 {
                font-size: 22px;
            }

            .carousel-caption p {
                font-size: 14px;
            }

        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            padding: 18px;
        }
    }
</style>

<div class="page-wrapper">

    <div class="content-wrapper">

        <div class="container">

            <!-- HERO SECTION -->
            <div class="hero-section">

                <h1>Product Management System</h1>

                <p>
                    Create, Update, Delete and Manage Products Easily
                </p>

                <a asp-controller="Products"
                   asp-action="Index"
                   class="btn btn-light btn-lg btn-custom mt-3">
                    View Products
                </a>

            </div>

            <!-- CAROUSEL -->
            <div id="mainCarousel"
                 class="carousel slide carousel-fade shadow mb-5"
                 data-bs-ride="carousel">

                <!-- INDICATORS -->
                <div class="carousel-indicators">
                    <button type="button"
                            data-bs-target="#mainCarousel"
                            data-bs-slide-to="0"
                            class="active">
                    </button>

                    <button type="button"
                            data-bs-target="#mainCarousel"
                            data-bs-slide-to="1">
                    </button>

                    <button type="button"
                            data-bs-target="#mainCarousel"
                            data-bs-slide-to="2">
                    </button>
                </div>

                <!-- SLIDES -->
                <div class="carousel-inner">

                    <div class="carousel-item active">
                        <img src="https://images.unsplash.com/photo-1556740749-887f6717d7e4?q=80&w=1400"
                             class="d-block w-100"
                             alt="Products">

                        <div class="carousel-caption">
                            <h3>Manage Products Easily</h3>
                            <p>Powerful Product Dashboard</p>
                        </div>
                    </div>

                    <div class="carousel-item">
                        <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=1400"
                             class="d-block w-100"
                             alt="Inventory">

                        <div class="carousel-caption">
                            <h3>Update Inventory</h3>
                            <p>Edit Product Information Quickly</p>
                        </div>
                    </div>

                    <div class="carousel-item">
                        <img src="https://images.unsplash.com/photo-1515169067868-5387ec356754?q=80&w=1400"
                             class="d-block w-100"
                             alt="Dashboard">

                        <div class="carousel-caption">
                            <h3>Modern Admin Panel</h3>
                            <p>Responsive pages and Good Design</p>
                        </div>
                    </div>

                </div>

                <!-- PREVIOUS -->
                <button class="carousel-control-prev"
                        type="button"
                        data-bs-target="#mainCarousel"
                        data-bs-slide="prev">

                    <span class="carousel-control-prev-icon"></span>

                </button>

                <!-- NEXT -->
                <button class="carousel-control-next"
                        type="button"
                        data-bs-target="#mainCarousel"
                        data-bs-slide="next">

                    <span class="carousel-control-next-icon"></span>

                </button>

            </div>

            <!-- FEATURES -->
            <h2 class="section-title">Product Operations</h2>

            <div class="row g-4">

                <div class="col-lg-3 col-md-6">
                    <div class="card feature-card shadow-sm h-100">
                        <div class="card-body text-center">

                            <div class="feature-icon text-primary">➕</div>

                            <h4>Create</h4>

                            <p>Add products to the system.</p>

                            <a asp-controller="Products"
                               asp-action="Create"
                               class="btn btn-primary btn-custom">
                                Add Product
                            </a>

                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card feature-card shadow-sm h-100">
                        <div class="card-body text-center">

                            <div class="feature-icon text-success">📋</div>

                            <h4>Product List</h4>

                            <p>View all available products.</p>

                            <a asp-controller="Products"
                               asp-action="Index"
                               class="btn btn-success btn-custom">
                                Show Products
                            </a>

                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card feature-card shadow-sm h-100">
                        <div class="card-body text-center">

                            <div class="feature-icon text-warning">✏️</div>

                            <h4>Update</h4>

                            <p>Edit existing products.</p>

                            <a asp-controller="Products"
                               asp-action="Index"
                               class="btn btn-warning text-white btn-custom">
                                Update
                            </a>

                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card feature-card shadow-sm h-100">
                        <div class="card-body text-center">

                            <div class="feature-icon text-danger">🗑️</div>

                            <h4>Delete</h4>

                            <p>Remove products securely.</p>

                            <a asp-controller="Products"
                               asp-action="Index"
                               class="btn btn-danger btn-custom">
                                Delete
                            </a>

                        </div>
                    </div>
                </div>

            </div>

            <!-- ABOUT -->
            <div class="row about-section align-items-center">

                <div class="col-md-6">
                    <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?q=80&w=1200"
                         class="img-fluid about-image"
                         alt="About">
                </div>

                <div class="col-md-6">

                    <h2 class="fw-bold text-primary mb-4">
                        Why Choose Our System?
                    </h2>

                    <p class="lead">
                        A professional solution for handling products,
                        inventory and management operations.
                    </p>

                    <ul class="list-group list-group-flush mt-4">
                        <li class="list-group-item">✅ Responsive Design</li>
                        <li class="list-group-item">✅ Easy CRUD Operations</li>
                        <li class="list-group-item">✅ Amazing UI</li>
                        <li class="list-group-item">✅ Great Customer support</li>
                    </ul>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const myCarousel = document.querySelector('#mainCarousel');

    new bootstrap.Carousel(myCarousel, {
    interval: 2500,   // ⏱️ change speed here (2000 = 2 seconds)
    ride: 'carousel',
    pause: false
    });
</script>