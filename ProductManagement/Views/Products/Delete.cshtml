@model ProductManagement.Models.Products

@{
    ViewData["Title"] = "Delete Product";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

    body {
        background: #fff5f5;
    }

    /* ================= HEADER ================= */

    .page-header {
        background: linear-gradient(135deg, #ef4444, #fca5a5);
        color: #7f1d1d;
        padding: 30px;
        border-radius: 18px;
        margin-bottom: 25px;
        box-shadow: 0 10px 25px rgba(239,68,68,0.2);
    }

        .page-header h2 {
            margin: 0;
            font-weight: 700;
        }

        .page-header p {
            margin: 5px 0 0;
            opacity: 0.85;
        }

    /* ================= CARD ================= */

    .details-card {
        background: white;
        border-radius: 18px;
        padding: 30px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        border: 1px solid #fee2e2;
    }

    /* ================= INFO BOX ================= */

    .info-box {
        display: flex;
        justify-content: space-between;
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 15px;
        background: #fef2f2;
        border: 1px solid #fecaca;
    }

    .info-label {
        font-weight: 600;
        color: #7f1d1d;
    }

    .info-value {
        font-weight: 600;
        color: #111827;
    }

    /* ================= PRICE BADGE ================= */

    .price-badge {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        padding: 10px 18px;
        border-radius: 30px;
        font-weight: 600;
    }

    /* ================= WARNING TEXT ================= */

    .warning-text {
        color: #b91c1c;
        font-weight: 600;
        margin-bottom: 15px;
    }

    /* ================= BUTTONS ================= */

    .btn-action {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        transition: 0.3s;
        border: none;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    .btn-delete {
        background: #ef4444;
        color: white;
    }

        .btn-delete:hover {
            background: #dc2626;
        }

    .btn-back {
        background: #e5e7eb;
        color: #111827;
    }

        .btn-back:hover {
            background: #d1d5db;
        }

    /* ================= BUTTON GROUP ================= */

    .btn-group-custom {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        flex-wrap: wrap;
    }

</style>

<!-- ================= HEADER ================= -->

<div class="page-header">

    <h2>
        <i class="bi bi-exclamation-triangle-fill"></i>
        Delete Product
    </h2>

    <p>Warning: This action cannot be undone</p>

</div>

<!-- ================= CONTENT ================= -->

<div class="details-card">

    <p class="warning-text">
        ⚠️ Are you sure you want to permanently delete this product?
    </p>

    <!-- PRODUCT NAME -->
    <div class="info-box">

        <span class="info-label">
            <i class="bi bi-box-seam"></i>
            Product Name
        </span>

        <span class="info-value">
            @Model.Name
        </span>

    </div>

    <!-- PRICE -->
    <div class="info-box">

        <span class="info-label">
            <i class="bi bi-cash"></i>
            Price
        </span>

        <span class="price-badge">
            ₹ @Model.Price
        </span>

    </div>

    <!-- FORM -->
    <form asp-action="Delete">

        <input type="hidden" asp-for="Id" />

        <div class="btn-group-custom">

            <button type="submit"
                    class="btn btn-action btn-delete">

                <i class="bi bi-trash-fill"></i>
                Yes, Delete

            </button>

            <a asp-action="Index"
               class="btn btn-action btn-back">

                <i class="bi bi-arrow-left-circle"></i>
                Cancel

            </a>

        </div>

    </form>

</div>