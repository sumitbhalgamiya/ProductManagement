@model IEnumerable<ProductManagement.Models.Products>

@{
    ViewData["Title"] = "Products";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

    body {
        background: #f4f7fb;
    }

    /* ================= HEADER ================= */

    .page-banner {
        background: linear-gradient(135deg, #0ea5e9, #14b8a6);
        border-radius: 22px;
        padding: 35px;
        color: white;
        margin-bottom: 30px;
        box-shadow: 0 10px 25px rgba(14,165,233,0.25);
    }

        .page-banner h2 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .page-banner p {
            margin: 0;
            opacity: 0.95;
        }

    /* ================= BUTTON ================= */

    .btn-create {
        background: white;
        color: #0ea5e9;
        border-radius: 14px;
        padding: 12px 22px;
        font-weight: 700;
        border: none;
        transition: 0.3s;
    }

        .btn-create:hover {
            background: #e0f2fe;
            transform: translateY(-2px);
        }

    /* ================= TABLE CARD ================= */

    .table-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
        border: 1px solid #e5e7eb;
    }

    /* ================= TABLE HEADER ================= */

    .table thead {
        background: linear-gradient(90deg, #0f172a, #1e293b);
        color: white;
    }

        .table thead th {
            padding: 18px;
            font-weight: 600;
            border: none;
        }

    /* ================= TABLE ROW ================= */

    .table tbody td {
        padding: 18px;
        vertical-align: middle;
        border-color: #f1f5f9;
        color: #374151;
    }

    .table tbody tr {
        transition: 0.25s;
    }

        .table tbody tr:hover {
            background: #f0f9ff;
        }

    /* ================= PRODUCT NAME ================= */

    .product-name {
        font-weight: 600;
        font-size: 16px;
    }

    /* ================= PRICE BADGE ================= */

    .price-badge {
        background: #dcfce7;
        color: #166534;
        padding: 8px 16px;
        border-radius: 30px;
        font-weight: 600;
        display: inline-block;
    }

    /* ================= ACTION BUTTONS ================= */

    .action-buttons {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-action {
        border-radius: 10px;
        padding: 8px 14px;
        font-size: 14px;
        font-weight: 600;
        transition: 0.25s;
        border: none;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    /* EDIT */
    .btn-edit {
        background: #dbeafe;
        color: #1d4ed8;
    }

        .btn-edit:hover {
            background: #bfdbfe;
        }

    /* DETAILS */
    .btn-details {
        background: #ccfbf1;
        color: #0f766e;
    }

        .btn-details:hover {
            background: #99f6e4;
        }

    /* DELETE */
    .btn-delete {
        background: #fee2e2;
        color: #991b1b;
    }

        .btn-delete:hover {
            background: #fecaca;
        }

    /* ================= RESPONSIVE ================= */

    @@media(max-width:768px) {

        .page-banner {
            text-align: center;
        }

        .action-buttons {
            flex-direction: column;
        }

            .action-buttons a {
                width: 100%;
            }
    }

</style>

<!-- ================= HEADER ================= -->

<div class="page-banner d-flex justify-content-between align-items-center flex-wrap">

    <div>
        <h2>
            <i class="bi bi-bag-fill"></i>
            Products Dashboard
        </h2>
        <p>Manage your product inventory in a clean and simple way</p>
    </div>

    <div class="mt-3 mt-md-0">
        <a asp-action="Create" class="btn btn-create">
            <i class="bi bi-plus-circle-fill"></i>
            Add Product
        </a>
    </div>

</div>

<!-- ================= TABLE ================= -->

<div class="table-card">

    <div class="table-responsive">

        <table class="table align-middle mb-0">

            <thead>
                <tr>
                    <th><i class="bi bi-box"></i> Product</th>
                    <th><i class="bi bi-cash"></i> Price</th>
                    <th class="text-center"><i class="bi bi-gear"></i> Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <span class="product-name">@item.Name</span>
                        </td>

                        <td>
                            <span class="price-badge">₹ @item.Price</span>
                        </td>

                        <td>

                            <div class="action-buttons">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-action btn-edit">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-action btn-details">
                                    <i class="bi bi-eye"></i> Details
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-action btn-delete">
                                    <i class="bi bi-trash"></i> Delete
                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>