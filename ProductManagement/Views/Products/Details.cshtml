@model ProductManagement.Models.Products

@{
    ViewData["Title"] = "Product Details";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

    body {
        background: #f6fbf7;
    }

    /* ================= HEADER ================= */

    .page-header {
        background: linear-gradient(135deg, #22c55e, #86efac);
        color: #064e3b;
        padding: 30px;
        border-radius: 18px;
        margin-bottom: 25px;
        box-shadow: 0 10px 25px rgba(34,197,94,0.2);
    }

        .page-header h2 {
            margin: 0;
            font-weight: 700;
        }

        .page-header p {
            margin: 5px 0 0;
            opacity: 0.85;
        }

    /* ================= CARD ================= */

    .details-card {
        background: white;
        border-radius: 18px;
        padding: 30px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        border: 1px solid #e5f3ea;
    }

    /* ================= INFO BOX ================= */

    .info-box {
        display: flex;
        justify-content: space-between;
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 15px;
        background: #ecfdf5;
        border: 1px solid #bbf7d0;
    }

    .info-label {
        font-weight: 600;
        color: #14532d;
    }

    .info-value {
        font-weight: 600;
        color: #064e3b;
    }

    /* ================= PRICE BADGE ================= */

    .price-badge {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        padding: 10px 18px;
        border-radius: 30px;
        font-weight: 600;
    }

    /* ================= BUTTONS ================= */

    .btn-action {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        transition: 0.3s;
        border: none;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    .btn-edit {
        background: #22c55e;
        color: white;
    }

        .btn-edit:hover {
            background: #16a34a;
        }

    .btn-back {
        background: #e5e7eb;
        color: #111827;
    }

        .btn-back:hover {
            background: #d1d5db;
        }

    /* ================= BUTTON GROUP ================= */

    .btn-group-custom {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        flex-wrap: wrap;
    }

</style>

<!-- ================= HEADER ================= -->

<div class="page-header">

    <h2>
        <i class="bi bi-eye-fill"></i>
        Product Details
    </h2>

    <p>View complete product information</p>

</div>

<!-- ================= DETAILS CARD ================= -->

<div class="details-card">

    <!-- PRODUCT NAME -->
    <div class="info-box">

        <span class="info-label">
            <i class="bi bi-box-seam"></i>
            Product Name
        </span>

        <span class="info-value">
            @Model.Name
        </span>

    </div>

    <!-- PRICE -->
    <div class="info-box">

        <span class="info-label">
            <i class="bi bi-cash"></i>
            Price
        </span>

        <span class="price-badge">
            ₹ @Model.Price
        </span>

    </div>

    <!-- ACTIONS -->
    <div class="btn-group-custom">

        <a asp-action="Edit"
           asp-route-id="@Model?.Id"
           class="btn btn-action btn-edit">

            <i class="bi bi-pencil-square"></i>
            Edit Product

        </a>

        <a asp-action="Index"
           class="btn btn-action btn-back">

            <i class="bi bi-arrow-left-circle"></i>
            Back to List

        </a>

    </div>

</div>